# Dateisystem
MAX_FILE_SIZE=10737418240  # 10GB
MAX_TIMELINE_EVENTS=1000000

# UAC
UAC_PROFILE=ir_triage
UAC_TIMEOUT=600

# Dissect
DISSECT_TIMEOUT=3600

# TSK
TSK_MAX_DEPTH=10
TSK_RECURSIVE=true

# LLM
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama3.1
LLM_TIMEOUT=120
LLM_TEMP_ANOMALY=0.3
LLM_TEMP_TIMELINE=0.5
LLM_TEMP_REPORT=0.4
LLM_MAX_TOKENS=2000

# RAG
RAG_ENABLED=true
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false

# CORS
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Anomaly Detection
ANOMALY_CONTAMINATION=0.1
ANOMALY_THRESHOLD=0.5

# Jobs
JOB_CLEANUP_DAYS=7
JOB_MAX_CONCURRENT=3

# Features
FEATURE_WEB_SEARCH=false
FEATURE_LLM_ANALYSIS=true
FEATURE_RAG=true
FEATURE_ANOMALY_DETECTION=true
FEATURE_AUTO_CLEANUP=true